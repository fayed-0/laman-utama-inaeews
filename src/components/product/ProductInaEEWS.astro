---
import { Image } from 'astro:assets';
import simap from '../../assets/simap.png';
---

<section class="min-h-screen snap-start w-full py-20 md:py-24 bg-white dark:bg-slate-900 px-12 md:px-24 transition-colors duration-500 overflow-hidden">
	<div class="mx-auto flex max-w-7xl flex-col items-center gap-8">
		<!-- Section Header -->
		<div class="flex flex-col items-center gap-3 w-full">
			<h2 class="text-3xl md:text-4xl font-bold text-center">
				<span class="text-slate-900 dark:text-white">Produk</span>
				<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-blue-700 dark:from-blue-400 dark:to-blue-500"> InaEEWS</span>
			</h2>
		</div>

		<div class="w-full max-w-2xl">
			<p class="text-center text-base md:text-lg leading-relaxed text-slate-600 dark:text-slate-400">
				SIMAP memberikan informasi cepat mengenai tingkat kekuatan guncangan gempa berdasarkan data dari sensor BMKG.
			</p>
		</div>
		<Image
			src={simap}
			alt="Produk InaEEWS"
			class="w-full rounded-2xl shadow-lg border border-slate-200 dark:border-slate-700"
		/>
	</div>
</section>