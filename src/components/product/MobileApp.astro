---
import mobileIcon from '../../assets/mobilephone.svg?url';
import timeIcon from '../../assets/time.svg?url';
import dollarIcon from '../../assets/dollar.svg?url';
import pinmapIcon from '../../assets/pinmap.svg?url';
import notifIcon from '../../assets/notif.svg?url';
import beatIcon from '../../assets/beat.svg?url';
import downloadIcon from '../../assets/download.svg?url';
import pageIcon from '../../assets/page.svg?url';
---

<section class="min-h-screen snap-start w-full py-20 md:py-24 bg-white dark:bg-slate-800 px-12 md:px-24 transition-colors duration-500 overflow-hidden">
	<div class="mx-auto flex max-w-7xl flex-col items-center gap-8">
		<!-- Section Header -->
		<div class="flex flex-col items-center gap-3 w-full">
			<h2 class="text-3xl md:text-4xl font-bold text-center">
				<span class="text-slate-900 dark:text-white">Aplikasi</span>
				<span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-blue-700 dark:from-blue-400 dark:to-blue-500"> Mobile</span>
			</h2>
		</div>

		<!-- Description -->
		<div class="w-full max-w-2xl">
			<p class="text-center text-base md:text-lg leading-relaxed text-slate-600 dark:text-slate-400">
				Lorem ipsum dolor sit amet consectetur adipiscing elit. Quisque faucibus ex sapien vitae pellentesque sem placerat.
			</p>
		</div>

		<!-- App Content -->
		<div class="w-full grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-8 items-center">
			<!-- Left Content Card -->
			<div class="bg-white dark:bg-slate-700 rounded-2xl shadow-lg border border-slate-200 dark:border-slate-600 p-7 md:p-10 space-y-7 transition-colors duration-500">
				<!-- Badge -->
				<div class="inline-flex px-4 py-2 bg-blue-50 dark:bg-blue-900/30 rounded-full border border-blue-200 dark:border-blue-800/50 transition-colors duration-500">
					<span class="text-xs md:text-sm font-bold uppercase tracking-wider text-blue-600 dark:text-blue-400">
						Tersedia Sekarang
					</span>
				</div>

				<!-- Title -->
				<h3 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white leading-tight">
					InaEEWS Mobile App
				</h3>

				<!-- Description -->
				<p class="text-sm md:text-base leading-relaxed text-slate-600 dark:text-slate-400">
					Lorem ipsum dolor sit amet consectetur adipiscing elit. Quisque faucibus ex sapien vitae pellentesque sem placerat. In id cursus mi pretium tellus duis convallis. Tempus leo eu aenean sed diam urna tempor. Lorem ipsum dolor sit amet consectetur adipiscing elit. 
				</p>

				<!-- Features Grid -->
				<div class="grid grid-cols-2 gap-3 md:gap-4 pt-3">
					{[
						{ icon: mobileIcon, text: 'Android & iOS' },
						{ icon: timeIcon, text: 'Latensi < 3 detik' },
						{ icon: dollarIcon, text: 'Gratis' },
						{ icon: pinmapIcon, text: 'Peta Interaktif' },
						{ icon: notifIcon, text: 'Notifikasi Otomatis' },
						{ icon: beatIcon, text: 'Riwayat Gempa' }
					].map(feature => (
						<div class="flex items-center gap-3 px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg text-xs md:text-sm text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-600/50 transition-colors">
							<img src={feature.icon} alt={feature.text} class="w-5 h-5" />
							<span className="font-medium">{feature.text}</span>
						</div>
					))}
				</div>

				<!-- Action Buttons -->
				<div class="flex flex-col gap-3 pt-6 w-full">
					<button class="flex items-center justify-center gap-3 w-full px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-bold text-sm md:text-base transition-colors">
						<img src={downloadIcon} alt="Download" class="w-5 h-5" style="filter: brightness(0) invert(1)" />
						Download APP
					</button>
					<button class="flex items-center justify-center gap-3 w-full px-6 py-3 border border-slate-300 dark:border-slate-600 text-slate-600 dark:text-slate-300 rounded-lg font-bold text-sm md:text-base hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors bg-white dark:bg-slate-700">
						<img src={pageIcon} alt="Panduan" class="w-5 h-5" />
						Panduan Pengguna
					</button>
				</div>
			</div>

			<!-- Right Image Placeholder -->
			<div class="w-full h-96 md:h-full min-h-96 bg-gradient-to-br from-slate-200 to-slate-300 dark:from-slate-600 dark:to-slate-700 rounded-2xl shadow-lg flex items-center justify-center transition-colors duration-500">
				<span class="text-slate-500 dark:text-slate-400 text-center px-4">
					<div class="text-sm md:text-base font-medium">tempat gambar</div>
				</span>
			</div>
		</div>
	</div>
</section>
			</div>
		</div>
	</div>
</section>

<style>
	.work-sans {
		font-family: 'Work Sans', sans-serif;
	}
</style>
