---
---

<section class="min-h-screen snap-start w-full flex items-center py-20 bg-white dark:bg-slate-900 transition-colors duration-500 overflow-hidden relative">
  <!-- Dynamic BG Elements -->
  <div class="absolute inset-0 z-0 pointer-events-none opacity-20 dark:opacity-40">
    <div class="absolute top-[20%] right-[10%] w-[30%] h-[30%] rounded-full bg-blue-400 blur-[150px] animate-pulse"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10 w-full">
    <div class="flex flex-col lg:flex-row items-center gap-12">
      <div class="lg:w-1/3 space-y-8">
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-300 text-sm font-bold uppercase tracking-widest mb-6 border border-blue-200 dark:border-blue-800 shadow-sm transition-all duration-500">
          <span class="material-symbols-outlined text-sm mr-2">location_on</span>
          Status Purwarupa
        </div>
        
        <h2 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white leading-tight">
          Wilayah <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-indigo-600 dark:from-blue-400 dark:to-indigo-400">Purwarupa InaEEWS</span>
        </h2>
        
        <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed max-w-xl">
          Saat ini, sistem memasuki tahap optimasi dan uji coba pada wilayah purwarupa dengan kerentanan seismik tinggi serta didukung oleh densitas jaringan sensor yang mumpuni.
        </p>
        
        <div class="grid grid-cols-1 gap-4">
          {[
            { id: 'LAMPUNG', name: "Lampung", desc: "Pesisir Barat & Bandar Lampung" },
            { id: 'BANTEN', name: "Banten", desc: "Serang & Cilegon" },
            { id: 'JAWA BARAT', name: "Jawa Barat", desc: "Bandung, Bogor & Sekitarnya" },
            { id: 'JAKARTA', name: "DKI Jakarta", desc: "Ibukota Negara & Infrastruktur Vital" }
          ].map(area => (
            <div 
              class="p-6 rounded-2xl bg-slate-50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-700/50 group hover:border-blue-500 transition-all duration-300 transform hover:-translate-x-2 cursor-pointer area-card"
              data-center={area.name}
              data-id={area.id}
            >
              <div class="flex items-center mb-2">
                <div class="w-3 h-3 rounded-full mr-3 bg-blue-500 shadow-[0_0_10px_#3b82f6]"></div>
                <h4 class="text-xl font-bold text-slate-900 dark:text-white group-hover:text-blue-600 transition-colors uppercase tracking-tight">{area.name}</h4>
              </div>
              <p class="text-sm text-slate-500 dark:text-slate-400">{area.desc}</p>
            </div>
          ))}
        </div>
      </div>
      
      <div class="lg:w-2/3 w-full h-[500px] lg:h-[750px]">
        <div class="relative w-full h-full group">
          <div class="absolute -inset-2 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-[2.5rem] blur opacity-10 group-hover:opacity-20 transition duration-1000 group-hover:duration-200"></div>
          <div class="relative w-full h-full rounded-[2rem] overflow-hidden border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-1 shadow-2xl">
            <div id="map" class="w-full h-full rounded-[1.5rem]"></div>
            
            <div class="absolute bottom-6 right-6 flex flex-col gap-2 z-10">
              <button id="zoom-in" class="w-10 h-10 bg-white/90 dark:bg-slate-800/90 backdrop-blur rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 flex items-center justify-center text-slate-600 dark:text-white hover:bg-blue-50 dark:hover:bg-blue-900/30 transition-colors">
                <span class="material-symbols-outlined text-lg">add</span>
              </button>
              <button id="zoom-out" class="w-10 h-10 bg-white/90 dark:bg-slate-800/90 backdrop-blur rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 flex items-center justify-center text-slate-600 dark:text-white hover:bg-blue-50 dark:hover:bg-blue-900/30 transition-colors">
                <span class="material-symbols-outlined text-lg">remove</span>
              </button>
              <button id="reset-map" class="w-10 h-10 bg-white/90 dark:bg-slate-800/90 backdrop-blur rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 flex items-center justify-center text-slate-600 dark:text-white hover:bg-blue-50 dark:hover:bg-blue-900/30 transition-colors">
                <span class="material-symbols-outlined text-lg">my_location</span>
              </button>
            </div>
            
            <div id="map-loader" class="absolute inset-0 bg-slate-50 dark:bg-slate-900 flex items-center justify-center z-20 transition-opacity duration-500">
               <div class="flex flex-col items-center">
                  <div class="w-12 h-12 border-4 border-blue-600 border-t-transparent rounded-full animate-spin mb-4"></div>
                  <p class="text-sm font-bold text-slate-500 uppercase tracking-widest">Memuat Peta Neon...</p>
               </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<link href="https://unpkg.com/maplibre-gl@latest/dist/maplibre-gl.css" rel="stylesheet" />
<script is:inline src="https://unpkg.com/maplibre-gl@latest/dist/maplibre-gl.js"></script>

<script is:inline>
  async function initMap() {
    const mapElement = document.getElementById('map');
    const loader = document.getElementById('map-loader');
    if (!mapElement) return;

    const centers = {
      'Lampung': [105.26, -5.3],
      'Banten': [106.15, -6.3],
      'Jawa Barat': [107.61, -7.0],
      'DKI Jakarta': [106.84, -6.17],
      'Full': [106.5, -6.4]
    };

    const map = new maplibregl.Map({
      container: 'map',
      style: {
        'version': 8,
        'sources': {
          'raster-tiles': {
            'type': 'raster',
            'tiles': [
              'https://tile.openstreetmap.org/{z}/{x}/{y}.png'
            ],
            'tileSize': 256,
            'attribution': '© OpenStreetMap'
          }
        },
        'layers': [
          {
            'id': 'simple-tiles',
            'type': 'raster',
            'source': 'raster-tiles',
            'paint': {
              'raster-opacity': 0.1,
              'raster-saturation': -1,
              'raster-brightness-min': 0,
              'raster-brightness-max': 1
            }
          }
        ]
      },
      center: centers['Full'],
      zoom: 7,
      pitch: 40,
      bearing: 0,
      antialias: true
    });

    const isDark = () => document.documentElement.classList.contains('theme-dark');
    
    function updateMapStyle() {
      const dark = isDark();
      if (map.getLayer('simple-tiles')) {
          map.setPaintProperty('simple-tiles', 'raster-opacity', dark ? 0.05 : 0.15);
          map.setPaintProperty('simple-tiles', 'raster-brightness-min', dark ? 0 : 0.1);
      }
    }

    map.on('load', async () => {
      updateMapStyle();
      
      const observer = new MutationObserver(updateMapStyle);
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

      try {
        const response = await fetch('https://cdn.jsdelivr.net/gh/superpikar/indonesia-geojson@master/indonesia-province-simple.json');
        if (!response.ok) throw new Error('Data layer tidak terjangkau');
        const data = await response.json();
        
        loader.style.opacity = '0';
        setTimeout(() => loader.style.display = 'none', 500);

        // Filter: Banten seringkali ditulis 'BANTEN' atau 'PROVINSI BANTEN'
        // Jakarta seringkali 'DKI JAKARTA' atau 'JAKARTA'
        const targets = ['LAMPUNG', 'BANTEN', 'JAWA BARAT', 'JAKARTA', 'DKI JAKARTA'];
        const filteredFeatures = data.features.filter(f => {
            const prop = (f.properties.Propinsi || f.properties.name || f.properties.NAME_1 || '').toUpperCase();
            return targets.some(t => prop.includes(t));
        });

        map.addSource('prototype-areas', {
          'type': 'geojson',
          'data': {
            'type': 'FeatureCollection',
            'features': filteredFeatures
          }
        });

        // Layer: Neon Glow
        map.addLayer({
          'id': 'areas-glow',
          'type': 'line',
          'source': 'prototype-areas',
          'paint': {
            'line-color': '#3b82f6',
            'line-width': 15,
            'line-blur': 12,
            'line-opacity': 0.6
          }
        });

        // Layer: Neon Edge
        map.addLayer({
          'id': 'areas-line',
          'type': 'line',
          'source': 'prototype-areas',
          'paint': {
            'line-color': '#60a5fa',
            'line-width': 2.5,
            'line-opacity': 1
          }
        });

        // Layer: Fill (Semua biru agar konsisten)
        map.addLayer({
          'id': 'areas-fill',
          'type': 'fill',
          'source': 'prototype-areas',
          'paint': {
            'fill-color': '#3b82f6',
            'fill-opacity': 0.15
          }
        });

        map.on('mousemove', 'areas-fill', (e) => {
           map.setPaintProperty('areas-fill', 'fill-opacity', [
             'case',
             ['==', ['get', 'Propinsi'], e.features[0].properties.Propinsi],
             0.5, 0.15
           ]);
           mapElement.style.cursor = 'pointer';
        });

        map.on('mouseleave', 'areas-fill', () => {
           map.setPaintProperty('areas-fill', 'fill-opacity', 0.15);
           mapElement.style.cursor = '';
        });

      } catch (err) {
        console.error('Error loading map:', err);
        loader.innerHTML = '<p class="text-red-500 font-bold">Gagal memuat data geografis</p>';
      }
    });

    document.querySelectorAll('.area-card').forEach(card => {
      card.addEventListener('mouseenter', () => {
        const centerName = card.getAttribute('data-center');
        const areaId = card.getAttribute('data-id');
        
        if (centers[centerName]) {
          map.flyTo({
            center: centers[centerName],
            zoom: centerName === 'DKI Jakarta' ? 10 : 8.5,
            speed: 1,
            essential: true
          });
        }

        if (map.getLayer('areas-fill')) {
           map.setPaintProperty('areas-fill', 'fill-opacity', [
             'case',
             ['any', 
               ['in', areaId, ['upcase', ['coalesce', ['get', 'Propinsi'], ['get', 'name'], ['get', 'NAME_1'], '']]]
             ],
             0.6, 0.15
           ]);
        }
      });
      
      card.addEventListener('mouseleave', () => {
         if (map.getLayer('areas-fill')) {
            map.setPaintProperty('areas-fill', 'fill-opacity', 0.15);
         }
      });
    });

    document.getElementById('zoom-in').onclick = () => map.zoomIn();
    document.getElementById('zoom-out').onclick = () => map.zoomOut();
    document.getElementById('reset-map').onclick = () => map.flyTo({ center: centers['Full'], zoom: 7, pitch: 40, bearing: 0 });
  }

  document.addEventListener('DOMContentLoaded', initMap);
</script>

<style>
  #map {
    background-color: #f1f5f9;
  }
  :global(.theme-dark) #map {
    background-color: #101828;
  }
</style>
