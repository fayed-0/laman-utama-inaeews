<style>
	svg circle {
		pointer-events: auto;
	}

	svg g:hover circle {
		stroke: #3b82f6 !important;
		stroke-width: 4 !important;
	}

	#tl-popup {
		position: absolute;
		background: white;
		border: 1px solid #dbeafe;
		border-radius: 8px;
		padding: 12px;
		box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
		z-index: 50;
		max-width: 280px;
		display: none;
		pointer-events: none;
	}

	#tl-popup strong {
		display: block;
		margin-bottom: 6px;
		font-size: 14px;
		color: #1e3a5f;
		font-weight: 600;
	}

	#tl-popup p {
		font-size: 13px;
