---
import Footer from '../Footer.astro';

// Logo mitra via URL. Ganti logoSrc dengan URL gambar logo resmi masing-masing.
const partners = [
//	{ logoSrc: 'https://www.brin.go.id/images/logo.png', url: 'https://www.brin.go.id' },
//	{ logoSrc: 'https://kcic.co.id/lkapp/wp-content/uploads/2023/11/cropped-KCIC-red.png', url: 'https://kcic.co.id' },
//	{ logoSrc: 'https://upload.wikimedia.org/wikipedia/commons/b/b7/Logo_BNPB.png', url: 'https://www.bnpb.go.id' },
//	{ logoSrc: 'https://upload.wikimedia.org/wikipedia/commons/2/23/MRT_Jakarta_logo_vertical.svg', url: 'https://jakartamrt.co.id/id' },
];
---

<section id="collaborate" class="snap-start w-full bg-slate-100 border-t border-slate-200">
	<div class="max-w-6xl mx-auto py-16 md:py-24 px-6 md:px-12">
		<h2 class="text-center text-slate-900 font-black text-xl md:text-2xl uppercase tracking-wide mb-14 md:mb-20">
			Berkolaborasi Dengan
		</h2>

		<div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-10 md:gap-x-16 md:gap-y-12">
			{partners.map((partner) => (
				<a
					href={partner.url}
					target={partner.url.startsWith('http') ? '_blank' : undefined}
					rel={partner.url.startsWith('http') ? 'noopener noreferrer' : undefined}
					class="flex flex-col items-center gap-3 text-slate-500 hover:text-slate-700 transition-colors group"
				>
					<div class="h-14 md:h-16 flex items-center justify-center relative">
						{partner.logoSrc ? (
							<img
								src={partner.logoSrc}
								class="max-h-full w-auto object-contain grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all logo-img"
							/>
						) : null}
						<span class={`flex items-center justify-center text-xl md:text-2xl font-bold uppercase tracking-wide text-slate-400 group-hover:text-slate-600 logo-fallback ${partner.logoSrc ? 'hidden absolute inset-0' : ''}`} data-fallback={partner.name}>{partner.name}</span>
					</div>
					<span class="text-[10px] md:text-xs font-bold uppercase tracking-widest text-slate-400">{partner.name}</span>
				</a>
			))}
		</div>
	</div>

	<Footer />
</section>

<script>
	// Fallback teks jika gambar logo dari URL gagal dimuat
	document.querySelectorAll('.logo-img').forEach((img) => {
		img.addEventListener('error', function () {
			const wrap = this.closest('a');
			const fallback = wrap?.querySelector('.logo-fallback');
			if (fallback) {
				this.style.display = 'none';
				fallback.classList.remove('hidden');
			}
		});
	});
</script>
