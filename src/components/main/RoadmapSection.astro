---

const roadmapItems = [
	{
		side: 'right',
		icon: 'policy',
		title: 'Regulasi dan Perluasan (Jawa)',
		bullets: [
			'Memperkuat aspek regulasi',
			'Pemasangan sensor (Jawa Tengah, Ibu Kota Negara)',
			'Pemetaan site classification (Sumatera 1)',
			'Integrasi dengan pengguna khusus (KCIC, dan transportasi lainnya)',
		],
	},
	{
		side: 'left',
		icon: 'tv_displays',
		title: 'Penyiaran TV Digital dan Perluasan (Sumatera 1)',
		bullets: [
			'Integrasi dengan penyebaran informasi melalui TV',
			'Pemasangan sensor (Sumatra 1)',
			'Pemasangan sensor (Sumatra 2)',
			'Integrasi dengan pengguna khusus (Gedung Komersial)',
			'Pengembangan metode berbasis AI',
			'Uji operasional regional (BMKG Regional Wilayah I dan BMKG Regional Wilayah II)',
		],
	},
	{
		side: 'right',
		icon: 'assignment',
		title: 'Diseminasi Baru dan Perluasan (Sumatera 2)',
		bullets: [
			'Pengenalan metode diseminasi Publik EEWS baru',
			'Pemasangan sensor (Sumatra 2)',
			'Pemetaan Site Classification (Nusa Tenggara, Sulawesi 1)',
			'Integrasi dengan pengguna khusus (responden pertama, Pendidikan)',
			'Pengembangan metode berbasis AI',
			'Uji operasional regional (Sanglah / BMKG Regional Wilayah III)',
		],
	},
	{
		side: 'left',
		icon: 'assignment_add',
		title: 'Regulasi dan Perluasan (Sulawesi)',
		bullets: [
			'Memperkuat aspek regulasi',
			'Pemasangan sensor (Nusa Tenggara, Sulawesi 1)',
			'Pemetaan site classification (Sulawesi 2, Maluku 1)',
			'Integrasi dengan pengguna khusus (layanan kesehatan)',
			'Uji operasional regional (BMKG Regional Wilayah IV)',
		],
	},
];
---

<section id="roadmap" class="min-h-screen w-full snap-start flex flex-col items-center py-24 px-6 md:px-12 relative overflow-hidden bg-white">
	
	<div class="text-left w-full max-w-5xl mb-20">
		<h2 class="text-4xl font-black tracking-tight text-slate-900">
			Status <span class="text-blue-600">Pengembangan Sistem</span>
		</h2>
	</div>

	<div class="relative w-full max-w-6xl mx-auto">
		<div class="absolute left-1/2 top-0 bottom-0 w-[2px] -translate-x-1/2 bg-gradient-to-b from-blue-50 via-blue-200 to-blue-50 hidden md:block">
			<div class="absolute top-0 left-1/2 -translate-x-1/2 w-4 h-full bg-blue-400/5 blur-sm"></div>
		</div>

		<div class="space-y-4 md:space-y-0"> {roadmapItems.map((item, i) => (
				<div class="relative flex flex-col md:flex-row md:items-start justify-center group">
					
					{/* Desktop Left Side Content */}
					<div class="hidden md:flex md:w-[45%] justify-end">
						{item.side === 'left' && (
							<div class="w-full max-w-md rounded-[2rem] bg-blue-50/40 border border-blue-100/50 p-8 text-slate-800 shadow-sm backdrop-blur-sm mb-12">
								<h4 class="font-black text-slate-900 mb-4 text-lg leading-tight">{item.title}</h4>
								<ul class="space-y-3 text-[13px] text-slate-500 font-medium">
									{item.bullets.map((b) => (
										<li class="flex gap-3">
											<span class="text-blue-300 mt-1.5 shrink-0 text-[10px]">•</span>
											<span class="leading-relaxed">{b}</span>
										</li>
									))}
								</ul>
							</div>
						)}
					</div>

					{/* Icon - Always visible, centered between sides on desktop, top on mobile */}
					<div class="relative z-10 flex flex-col items-center md:mx-12 py-4 order-first md:order-none">
						<div class="size-14 rounded-full bg-white border-2 border-blue-100 flex items-center justify-center text-blue-500 shadow-xl shadow-blue-200/50 group-hover:scale-110 transition-transform duration-300">
							<span class="material-symbols-outlined text-2xl">{item.icon}</span>
						</div>
						{/* Mobile Connector */}
						<div class="w-[2px] h-8 bg-blue-100 md:hidden"></div>
					</div>

					{/* Mobile Content & Desktop Right Side Content */}
					<div class="flex md:w-[45%] justify-start">
						{/* On mobile: always show. On desktop: only show if side is right */}
						<div class={`w-full max-w-md rounded-[2rem] bg-blue-50/40 border border-blue-100/50 p-8 text-slate-800 shadow-sm backdrop-blur-sm mb-12 ${item.side === 'left' ? 'md:hidden' : ''}`}>
							<h4 class="font-black text-slate-900 mb-4 text-lg leading-tight">{item.title}</h4>
							<ul class="space-y-3 text-[13px] text-slate-500 font-medium">
								{item.bullets.map((b) => (
									<li class="flex gap-3">
										<span class="text-blue-300 mt-1.5 shrink-0 text-[10px]">•</span>
										<span class="leading-relaxed">{b}</span>
									</li>
								))}
							</ul>
						</div>
					</div>
				</div>
			))}

			<div class="flex justify-center pt-4">
				<div class="size-14 rounded-full bg-white border-2 border-blue-100 flex items-center justify-center text-blue-500 shadow-sm shadow-blue-200/50">
					<span class="material-symbols-outlined text-2xl">science</span>
				</div>
			</div>
		</div>
	</div>

	
</section>