---
import dropIcon from '../../assets/icon/drop.png';
import coverIcon from '../../assets/icon/cover.png';
import holdIcon from '../../assets/icon/hold.png';
---

<section id="golden-time" class="min-h-screen w-full snap-start flex flex-col items-center justify-center px-6 md:px-12 py-24 bg-blue-50 relative overflow-hidden">
	<div class="text-center mb-10 md:mb-12 flex flex-col items-center relative">
		<h2 class="text-5xl md:text-6xl font-black tracking-tighter text-slate-900 relative z-10">Golden <span class="text-blue-600">Time.</span></h2>
		<div class="w-16 md:w-20 h-1 bg-emerald-600 mt-4"></div>
	</div>
	
	<div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl w-full">
		<div class="bg-white border border-slate-100 p-8 md:p-10 rounded-[2rem] md:rounded-[2.5rem] flex flex-col items-center text-center gap-6 transform hover:-translate-y-2 transition-transform shadow-sm">
			<div class="flex flex-col items-center gap-2 text-slate-900">
				<img src={dropIcon.src} alt="Drop - Merunduk" class="h-12 md:h-16 w-auto object-contain" />
			</div>
			<div class="h-px bg-slate-100 w-full"></div>
			<div>
				<h4 class="text-xl font-black uppercase text-slate-900">DROP!</h4>
				<h4 class="text-sm font-black text-blue-600 uppercase">MERUNDUK</h4>
			</div>
			<p class="text-slate-500 text-sm italic font-medium">Segera merunduk sambil lindungi leher dan kepala Anda.</p>
		</div>

		<div class="bg-white border border-slate-100 p-8 md:p-10 rounded-[2rem] md:rounded-[2.5rem] flex flex-col items-center text-center gap-6 transform hover:-translate-y-2 transition-transform shadow-sm">
			<div class="flex flex-col items-center gap-2 text-slate-900">
				<img src={coverIcon.src} alt="Cover - Berlindung" class="h-12 md:h-16 w-auto object-contain" />
			</div>
			<div class="h-px bg-slate-100 w-full"></div>
			<div>
				<h4 class="text-xl font-black text-slate-900 uppercase">COVER!</h4>
				<h4 class="text-sm font-black text-blue-600 uppercase">berlindung</h4>
			</div>
			<p class="text-slate-500 text-sm italic font-medium">Berlindung di bawah meja yang kokoh. Lindungi leher dan kepala Anda.</p>
		</div>

		<div class="bg-white border border-slate-100 p-8 md:p-10 rounded-[2rem] md:rounded-[2.5rem] flex flex-col items-center text-center gap-6 transform hover:-translate-y-2 transition-transform shadow-sm">
			<div class="flex flex-col items-center gap-2 text-slate-900">
				<img src={holdIcon.src} alt="Hold On - Bertahan" class="h-12 md:h-16 w-auto object-contain" />
			</div>
			<div class="h-px bg-slate-100 w-full"></div>
			<div>
				<h4 class="text-xl font-black text-slate-900 uppercase">HOLD ON!</h4>
				<h4 class="text-sm font-black text-blue-600 uppercase">Bertahan</h4>
			</div>
			<p class="text-slate-500 text-sm italic font-medium">Tetap berlindung hingga guncangan benar-benar berakhir sepenuhnya.</p>
		</div>
	</div>
</section>
