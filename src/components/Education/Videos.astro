---
// Video Edukasi Section
---

<section class="snap-start w-full bg-white py-24 px-12 md:px-24 overflow-hidden">
  <div class="max-w-7xl mx-auto flex flex-col gap-12">
    <!-- Header -->
    <div class="flex flex-col items-center gap-3">
      <h2 class="text-center text-4xl font-bold">
        <span class="text-slate-800">Video </span>
        <span class="text-blue-600">Edukasi</span>
      </h2>
      <p class="text-center text-slate-400 text-base max-w-2xl">
        Kumpulan video edukasi, seputar sistem peringatan dini gempa bumi Indonesia.
      </p>
      <button class="group/btn flex-shrink-0 inline-flex items-center gap-1.5 px-3 py-2 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-full border border-blue-200 dark:border-blue-800/50 text-xs font-bold uppercase tracking-wider hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors">
        Lihat semua
        <svg class="w-4 h-4 group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
		</svg>
      </button>
    </div>

    <!-- Videos Grid - First Row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[1, 2, 3].map(() => (
        <div class="bg-white rounded-2xl shadow-md border border-slate-100 overflow-hidden hover:shadow-lg transition-shadow">
          <!-- Video Thumbnail -->
          <div class="relative h-48 bg-gradient-to-br from-blue-100 to-blue-50 flex items-center justify-center overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-blue-100 to-cyan-50"></div>
            <button class="relative z-10 flex flex-col items-center gap-3 hover:scale-110 transition-transform">
              <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center shadow-lg">
                <svg class="w-6 h-6 text-white fill-current" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
              <span class="text-slate-600 text-xs font-bold uppercase tracking-wide">Tonton Video</span>
            </button>
          </div>
          
          <!-- Content -->
          <div class="p-5 space-y-3">
            <h3 class="text-slate-800 font-bold text-lg">Apa itu INAEEWS?</h3>
            <p class="text-slate-600 text-xs">BMKG Indonesia - 2025</p>
            <div class="border-t border-slate-200 pt-3 flex items-center justify-between">
              <span class="text-slate-600 text-xs flex items-center gap-1">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 6v6l4 2" stroke="white" stroke-width="2" fill="none"/>
                </svg>
                5 mnt
              </span>
              <span class="inline-block px-3 py-1 rounded text-blue-600 bg-blue-50 text-xs font-bold uppercase">
                Teknis
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Videos Grid - Second Row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[1, 2, 3].map(() => (
        <div class="bg-white rounded-2xl shadow-md border border-slate-100 overflow-hidden hover:shadow-lg transition-shadow">
          <!-- Video Thumbnail -->
          <div class="relative h-48 bg-gradient-to-br from-blue-100 to-blue-50 flex items-center justify-center overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-blue-100 to-cyan-50"></div>
            <button class="relative z-10 flex flex-col items-center gap-3 hover:scale-110 transition-transform">
              <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center shadow-lg">
                <svg class="w-6 h-6 text-white fill-current" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
              <span class="text-slate-600 text-xs font-bold uppercase tracking-wide">Tonton Video</span>
            </button>
          </div>
          
          <!-- Content -->
          <div class="p-5 space-y-3">
            <h3 class="text-slate-800 font-bold text-lg">Apa itu INAEEWS?</h3>
            <p class="text-slate-600 text-xs">BMKG Indonesia - 2025</p>
            <div class="border-t border-slate-200 pt-3 flex items-center justify-between">
              <span class="text-slate-600 text-xs flex items-center gap-1">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 6v6l4 2" stroke="white" stroke-width="2" fill="none"/>
                </svg>
                5 mnt
              </span>
              <span class="inline-block px-3 py-1 rounded text-blue-600 bg-blue-50 text-xs font-bold uppercase">
                Teknis
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
